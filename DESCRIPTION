Package: varGuid
Type: Package
Title: Variance-Guided Regression Improving Upon OLS and ANOVA
Version: 0.1.5.9000
Date: 2026-06-18
Authors@R: c(
    person(given = "Sibei", family = "Liu", email = "sxl4188@miami.edu", role = "aut"),
    person(given = "Min", family = "Lu", email = "luminwin@gmail.com", role = c("aut", "cre")))
